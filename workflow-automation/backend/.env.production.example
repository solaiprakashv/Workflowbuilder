PORT=5000
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@<cluster-host>/workflow_automation?retryWrites=true&w=majority
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=7d
NODE_ENV=production

# Comma-separated list for deployed frontends
CLIENT_URLS=https://your-frontend.vercel.app

# Optional SMTP settings for notification steps
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
SMTP_FROM=
SMTP_FAMILY=4
SMTP_FORCE_IPV4=true

# Optional fallback when SMTP is blocked/times out in hosting
RESEND_API_KEY=
RESEND_FROM=
