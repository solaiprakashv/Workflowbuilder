PORT=5000
MONGODB_URI=mongodb://localhost:27017/workflow_automation
JWT_SECRET=<generate-a-strong-random-secret>
JWT_EXPIRES_IN=7d
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Optional SMTP settings for notification steps
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
SMTP_FROM=
SMTP_FAMILY=4
SMTP_FORCE_IPV4=true

# Optional fallback when SMTP is blocked/times out
RESEND_API_KEY=
RESEND_FROM=
